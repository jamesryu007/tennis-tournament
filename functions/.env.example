# 자미봇 API 키 설정
# .env 파일로 복사 후 실제 키를 입력하세요 (git에 커밋하지 마세요)

# OpenWeatherMap 날씨 API (무료: openweathermap.org/api)
OPENWEATHER_API_KEY=your_openweather_api_key_here

# 에어코리아 미세먼지 API (무료: data.go.kr)
AIRKOREA_API_KEY=your_airkorea_api_key_here

# 날씨 위치 (기본: 서울)
BOT_WEATHER_LAT=37.5665
BOT_WEATHER_LON=126.9780

# 미세먼지 측정소 (기본: 종로구)
BOT_AIR_STATION=종로구
